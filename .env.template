# Core runtime
QUANT_GPT_ENV=dev
QUANT_GPT_RUNTIME_ROOT=/mnt/nvme_data/shared/quant_gpt
QUANT_GPT_STATE_DB=/mnt/nvme_data/shared/quant_gpt/state/quant_gpt.db
QUANT_GPT_LOG_LEVEL=DEBUG
QUANT_GPT_PROVIDER_MODE=external_equivalent
QUANT_GPT_ENABLE_LLM=true
QUANT_GPT_LLM_MODE=observe_only
BACKTEST_MODE=cloud
LEAN_CLOUD_PUSH_ON_BACKTEST=true
LEAN_CLOUD_OPEN_RESULTS=false
LEAN_BACKTEST_PROJECT=QualityGrowthPi
LEAN_BACKTEST_PROJECT_ID=
QC_CLOUD_FILE_SYNC=true
QC_CODE_SOURCE_ID=quant_gpt_cli
PAPER_DEPLOYMENT_TARGET=cloud
PAPER_BROKER=alpaca
PAPER_ENVIRONMENT=paper
PAPER_LIVE_DATA_PROVIDER=QuantConnect
PAPER_HISTORICAL_DATA_PROVIDER=QuantConnect
LEAN_CLOUD_PUSH_ON_PAPER=true
LEAN_CLOUD_PAPER_NODE=
LEAN_CLOUD_PAPER_AUTO_RESTART=true
LEAN_CLOUD_PAPER_NOTIFY_ORDER_EVENTS=true
LEAN_CLOUD_PAPER_NOTIFY_INSIGHTS=false
LEAN_CLOUD_OPEN_PAPER=false
LOCAL_FUNDAMENTALS_PROVIDER=massive_sec_alpha_vantage
LOCAL_DAILY_BARS_PROVIDER=alpaca

# LEAN / QuantConnect
QUANTCONNECT_USER_ID=
QUANTCONNECT_API_TOKEN=
LEAN_ORGANIZATION_ID=
LEAN_DATA_DIRECTORY=/mnt/nvme_data/shared/quant_gpt/data/lean

# Alpaca paper/live
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_ENVIRONMENT=paper
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_MARKET_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex

# Market data providers
# Massive is the current name for Polygon.io. The adapter also accepts deprecated POLYGON_* variables.
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_FUNDAMENTALS_CACHE_PATH=/mnt/nvme_data/shared/quant_gpt/data/market_cache/massive/fundamentals_snapshot.jsonl
# Optional advanced override if Massive changes the official aggregates route shape in the future.
# MASSIVE_AGGREGATES_PATH_TEMPLATE=/v2/aggs/ticker/{ticker}/range/{multiplier}/{timespan}/{start}/{end}
# Optional advanced overrides for the current Massive financials/news endpoints.
# MASSIVE_RATIOS_PATH_TEMPLATE=/stocks/financials/v1/ratios
# MASSIVE_INCOME_STATEMENTS_PATH_TEMPLATE=/stocks/financials/v1/income-statements
# MASSIVE_NEWS_PATH_TEMPLATE=/v2/reference/news

# Alpha Vantage
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_FUNDAMENTALS_CACHE_PATH=/mnt/nvme_data/shared/quant_gpt/data/market_cache/alpha_vantage/fundamentals_snapshot.jsonl

# SEC public fundamentals
SEC_API_USER_AGENT=
SEC_FUNDAMENTALS_CACHE_PATH=/mnt/nvme_data/shared/quant_gpt/data/market_cache/sec/fundamentals_snapshot.jsonl

# LLM provider
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-3.1-flash-lite-preview
GEMINI_FALLBACK_MODEL_ID=gemini-3.1-flash
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GEMINI_TIMEOUT_SECONDS=12
GEMINI_MAX_RETRIES=2

# Broker / execution
BROKER_MODE=paper
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_ACCOUNT=
IBKR_CLIENT_ID=101

# Budgets and advisory policy
LLM_BUDGET_USD_DAILY=5.00
LLM_ESTIMATED_REQUEST_COST_USD=0.001
LLM_MAX_SYMBOLS_PER_BATCH=20
LLM_CACHE_TTL_MINUTES=240
LLM_REQUIRE_MANUAL_REVIEW=false

# Optional news configuration
NEWS_PROVIDER_MODE=composite
NEWS_FEED_PATH=/mnt/nvme_data/shared/quant_gpt/data/news_cache/news_feed.jsonl
