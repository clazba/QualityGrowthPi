# Core runtime
QUANT_GPT_ENV=dev
QUANT_GPT_RUNTIME_ROOT=/mnt/nvme_data/shared/quant_gpt
QUANT_GPT_STATE_DB=/mnt/nvme_data/shared/quant_gpt/state/quant_gpt.db
QUANT_GPT_LOG_LEVEL=DEBUG
QUANT_GPT_PROVIDER_MODE=quantconnect_local
QUANT_GPT_ENABLE_LLM=true
QUANT_GPT_LLM_MODE=observe_only

# LEAN / QuantConnect
QUANTCONNECT_USER_ID=
QUANTCONNECT_API_TOKEN=
LEAN_ORGANIZATION_ID=
LEAN_DATA_DIRECTORY=/mnt/nvme_data/shared/quant_gpt/data/lean

# Market data providers
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io

# LLM provider
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-3.1-flash-lite-preview
GEMINI_FALLBACK_MODEL_ID=gemini-3.1-flash
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GEMINI_TIMEOUT_SECONDS=12
GEMINI_MAX_RETRIES=2

# Broker / execution
BROKER_MODE=paper
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_ACCOUNT=
IBKR_CLIENT_ID=101

# Budgets and advisory policy
LLM_BUDGET_USD_DAILY=5.00
LLM_ESTIMATED_REQUEST_COST_USD=0.001
LLM_MAX_SYMBOLS_PER_BATCH=20
LLM_CACHE_TTL_MINUTES=240
LLM_REQUIRE_MANUAL_REVIEW=false

# Optional news configuration
NEWS_PROVIDER_MODE=file
NEWS_FEED_PATH=/mnt/nvme_data/shared/quant_gpt/data/news_cache/news_feed.jsonl
